# Site-wide password gate (defaults: password "house" + built-in token if unset).
# Set BOTH to override. Set SITE_AUTH_DISABLED=true to disable the gate entirely.
# Generate SITE_AUTH_TOKEN: openssl rand -hex 32
SITE_PASSWORD=
SITE_AUTH_TOKEN=
SITE_AUTH_DISABLED=

# Supabase — Settings → API
# Prefer the new names (Publishable / Secret). Legacy anon + service_role JWTs still work as fallbacks.
NEXT_PUBLIC_SUPABASE_URL=
# Publishable key (sb_publishable_…) — same as dashboard “Publishable”
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Legacy: anon public JWT if you do not use Publishable
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Secret key (sb_secret_…) — server only; same as dashboard “Secret”
SUPABASE_SECRET_KEY=
# Legacy name for the same secret key (optional if SUPABASE_SECRET_KEY is set)
SUPABASE_SERVICE_ROLE_KEY=

# Auth.js / NextAuth — required if you use Sign in (SessionProvider). Generate: openssl rand -base64 32
AUTH_SECRET=
# Optional Google OAuth
# AUTH_GOOGLE_ID=
# AUTH_GOOGLE_SECRET=
# AUTH_URL=http://localhost:3000
