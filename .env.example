# Site-wide password gate (set BOTH to enable). Never commit real values.
# Generate SITE_AUTH_TOKEN: openssl rand -hex 32
SITE_PASSWORD=
SITE_AUTH_TOKEN=

# Auth.js / NextAuth — required if you use Sign in (SessionProvider). Generate: openssl rand -base64 32
AUTH_SECRET=
# Optional Google OAuth
# AUTH_GOOGLE_ID=
# AUTH_GOOGLE_SECRET=
# AUTH_URL=http://localhost:3000
