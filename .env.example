# Site-wide password gate (defaults: password "house" + built-in token if unset).
# Set BOTH to override. Set SITE_AUTH_DISABLED=true to disable the gate entirely.
# Generate SITE_AUTH_TOKEN: openssl rand -hex 32
SITE_PASSWORD=
SITE_AUTH_TOKEN=
SITE_AUTH_DISABLED=

# Auth.js / NextAuth — required if you use Sign in (SessionProvider). Generate: openssl rand -base64 32
AUTH_SECRET=
# Optional Google OAuth
# AUTH_GOOGLE_ID=
# AUTH_GOOGLE_SECRET=
# AUTH_URL=http://localhost:3000
