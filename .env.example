# Site-wide password gate (defaults: password "house" + built-in token if unset).
# Set BOTH to override. Set SITE_AUTH_DISABLED=true to disable the gate entirely.
# Generate SITE_AUTH_TOKEN: openssl rand -hex 32
SITE_PASSWORD=
SITE_AUTH_TOKEN=
SITE_AUTH_DISABLED=

# Supabase — project URL + anon JWT (Settings → API). Never expose service role to the client.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only; full access. Optional: newer publishable key (sb_publishable_…) if you use APIs that require it.
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_PUBLISHABLE_KEY=

# Auth.js / NextAuth — required if you use Sign in (SessionProvider). Generate: openssl rand -base64 32
AUTH_SECRET=
# Optional Google OAuth
# AUTH_GOOGLE_ID=
# AUTH_GOOGLE_SECRET=
# AUTH_URL=http://localhost:3000
